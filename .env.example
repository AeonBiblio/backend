# Скопируйте в .env и задайте свои значения:
#   cp .env.example .env        (Linux/macOS)
#   copy .env.example .env      (Windows)
#
# Для docker compose: cp .env.example .env перед запуском.

# --- PostgreSQL (сервис db в docker-compose) ---
POSTGRES_USER=aeon
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=aeonbiblio

# --- Приложение: база данных ---
# Локально (без Docker): localhost. В Docker compose подставляет host db автоматически.
DATABASE_URL=postgresql+asyncpg://aeon:change-me-postgres-password@localhost:5432/aeonbiblio

# --- JWT ---
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-a-secure-random-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- MinIO (сервис minio в docker-compose) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password

# --- MinIO (приложение) ---
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY должны совпадать с MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-password
MINIO_BUCKET=aeonbiblio
MINIO_SECURE=false

# --- Приложение ---
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Тесты (опционально, только для pytest) ---
PYTEST_DATABASE_URL=postgresql+asyncpg://aeon:change-me-postgres-password@localhost:5432/aeonbiblio_test

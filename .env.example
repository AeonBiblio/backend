# Скопируйте в .env и задайте свои значения:
#   cp .env.example .env

# --- Сеть (docker compose) ---
# 127.0.0.1 — production за nginx (порты не торчат наружу)
# 0.0.0.0    — локальная разработка на машине разработчика
BIND_ADDRESS=127.0.0.1

# --- PostgreSQL (сервис db) ---
POSTGRES_USER=aeon
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=aeonbiblio

# Для pytest с хоста (контейнер app использует DATABASE_URL из compose)
DATABASE_URL=postgresql+asyncpg://aeon:change-me-postgres-password@localhost:5432/aeonbiblio

# --- JWT ---
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-a-secure-random-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- MinIO (сервис minio) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password

# --- MinIO (приложение) ---
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY = MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
MINIO_ENDPOINT=localhost:9000
# Публичный хост presigned URL (nginx → storage.*)
MINIO_PUBLIC_ENDPOINT=storage.aeonbiblio.chickenkiller.com
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-password
MINIO_BUCKET=aeonbiblio
MINIO_SECURE=true

# CORS для FastAPI и MinIO API (через запятую, без пробелов)
CORS_ORIGINS=https://aeonbiblio.chickenkiller.com

# CORS для bucket MinIO (JSON-массив origin'ов)
MINIO_CORS_ORIGINS_JSON=["https://aeonbiblio.chickenkiller.com"]

# --- Приложение ---
APP_ENV=production

# --- Локальная разработка (пример) ---
# BIND_ADDRESS=0.0.0.0
# MINIO_PUBLIC_ENDPOINT=localhost:9000
# MINIO_SECURE=false
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# MINIO_CORS_ORIGINS_JSON=["http://localhost:3000","http://localhost:5173"]
# APP_ENV=development

# --- Тесты (опционально) ---
PYTEST_DATABASE_URL=postgresql+asyncpg://aeon:change-me-postgres-password@localhost:5432/aeonbiblio_test
